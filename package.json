{
  "name": "ullo-batch",
  "version": "1.0.0",
  "description": "ullo 배치 시스템 (구독 자동결제 / 반복 스케줄 롤링 생성 / 정산 자동 생성)",
  "license": "ISC",
  "main": "dist/index.js",
  "scripts": {
    "dev": "nodemon --watch src --ext ts --exec ts-node src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "job": "ts-node src/cli.ts",
    "deploy:local": "npm run build && pm2 start ecosystem.config.js --env local",
    "deploy:prod": "npm run build && pm2 start ecosystem.config.js --env prod",
    "pm2:reload": "pm2 reload ullo-batch",
    "pm2:logs": "pm2 logs ullo-batch"
  },
  "dependencies": {
    "axios": "^1.7.0",
    "dotenv": "^16.4.5",
    "node-schedule": "^2.1.1",
    "p-retry": "^4.6.2",
    "pg": "^8.13.0",
    "reflect-metadata": "^0.2.2",
    "typeorm": "^0.3.20",
    "winston": "^3.15.0"
  },
  "devDependencies": {
    "@types/node": "^22.7.0",
    "@types/node-schedule": "^2.1.7",
    "nodemon": "^3.1.7",
    "ts-node": "^10.9.2",
    "typescript": "^5.6.0"
  }
}
